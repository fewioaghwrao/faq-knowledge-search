{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3307;Database=FaqAppDb;User=faqapp;Password=faqapp_pass;"
  },
  "JwtSettings": {
    "Issuer": "FaqApp.Api",
    "Audience": "FaqApp.Frontend",
    "Secret": "PLEASE_CHANGE_THIS_SECRET_KEY_FOR_DEVELOPMENT_ONLY_123456789",
    "ExpiresInMinutes": 60
  },
  "AdminSeed": {
    "Email": "admin@faq-app.local",
    "Password": "Password123!"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AiSettings": {
    "Provider": "OpenAI",
    "Model": "gpt-5.4-mini",
    "Endpoint": "https://api.openai.com/v1/responses",
    "TimeoutSeconds": 30,
    "MaxContextFaqCount": 5
  },
  "ENABLE_SWAGGER": true,
  "ENABLE_DB_MIGRATION": false,
  "ENABLE_DB_SEED": true,
  "AllowedHosts": "*"

}
